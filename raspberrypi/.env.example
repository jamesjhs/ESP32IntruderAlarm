# Shared Raspberry Pi server-side version.
APP_VERSION=0.0.1

# TypeScript PWA/API service.
PWA_HOST=127.0.0.1
PWA_PORT=3015
WORKER_INTERNAL_URL=http://127.0.0.1:3005

# Python ESP32 telemetry worker.
WORKER_HOST=0.0.0.0
WORKER_PORT=3005
ESP32_TELEMETRY_PATH=/espdata

# First install bootstrap. Disable after the first owner account is created.
APP_BOOTSTRAP_ENABLED=true
APP_ADMIN_USERNAME=owner
APP_ADMIN_PASSWORD=change-me-immediately

# SQLCipher key placeholder. The initial scaffold does not open the encrypted
# database yet, but deployments should reserve this variable from day one.
SQLCIPHER_KEY=replace-with-a-long-random-secret

# VAPID placeholders for Web Push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@example.com

# SMTP placeholders.
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Optional UDP probe traffic generated by the Python worker.
UDP_PROBE_ENABLED=false
UDP_PROBE_TARGET_IP=
UDP_PROBE_TARGET_PORT=9
UDP_PROBE_INTERVAL_SECONDS=5
UDP_PROBE_PAYLOAD=esp32-alarm-probe
